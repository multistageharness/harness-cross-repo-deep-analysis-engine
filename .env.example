# cross-repo-deep-analysis-engine (Node/TS) -- environment variables
# Copy to .env and fill in values. Never commit .env.

# ── LLM auth (GitHub Copilot harness) ─────────────────────────────────────────
# LLM nodes 5/6 run through the vendored `llm-sdk-github-copilot` harness, which
# drives the GitHub Copilot runtime. There is NO provider API key (no
# ANTHROPIC_API_KEY). Auth comes from the Copilot CLI itself:
#   - a prior interactive `copilot` login, or
#   - COPILOT_CLI_PATH pointing at a Copilot CLI entry the runtime can use.
# Leave these unset to use the SDK's bundled runtime + ambient auth.
COPILOT_CLI_PATH=
COPILOT_REASONING_EFFORT=

# ── Optional but recommended ──────────────────────────────────────────────────

# GitHub credential + clone host.
# Canonical source of truth is constant.mjs at the repo root — set GIT_TOKEN and
# GITHUB_BASE_HOST there, OR override here (env wins over the file defaults):
#   GIT_TOKEN         resolves as: GIT_TOKEN > GITHUB_TOKEN > constant.mjs default
#   GITHUB_BASE_HOST  clone host (no scheme), default github.com; set to a GitHub
#                     Enterprise Server host (e.g. github.mycorp.com) to clone there
# The token (read-only) is injected into HTTPS clone URLs and GitHub API auth.
# Without a token: 60 unauthenticated API requests/hour (shared by IP).
# With one: 5,000 authenticated requests/hour. Also enables private repo cloning.
GIT_TOKEN=
GITHUB_BASE_HOST=github.com

# Legacy alias for GIT_TOKEN — still honored as a fallback if GIT_TOKEN is unset.
GITHUB_TOKEN=

# ── Input ─────────────────────────────────────────────────────────────────────

# Path to the repos YAML or JSON file (default: repos.yaml in cwd)
REPOS_FILE=repos.yaml

# ── Model overrides (Copilot model ids) ───────────────────────────────────────
# These are GitHub Copilot model ids (not provider-API ids). Override to any
# model your Copilot runtime exposes.

# LLM model for stack analysis (node 5).
# Default: claude-opus-4.8 (deeper reasoning across multiple manifests)
ANALYSIS_MODEL=claude-opus-4.8

# Reasoning effort for node 5: low | medium | high | xhigh. Default: medium
ANALYSIS_EFFORT=medium

# Advisory output-size hint for node 5 (the harness has no hard output cap).
ANALYSIS_MAX_TOKENS=2048

# LLM model for random-file context summarization (node 6).
# Default: claude-haiku-4.5 (faster, cheaper; single-file task)
CONTEXT_MODEL=claude-haiku-4.5

# Reasoning effort for node 6: low | medium | high | xhigh. Default: low
CONTEXT_EFFORT=low

# Advisory output-size hint for node 6 (the harness has no hard output cap).
CONTEXT_MAX_TOKENS=512

# ── Tuning ────────────────────────────────────────────────────────────────────

# Maximum size in bytes of a random source file passed to node 6.
# Files exceeding this cap are skipped (never truncated silently).
# Default: 51200 (50 KB)
MAX_RANDOM_FILE_BYTES=51200

# Optional override for the GitHub REST API base URL (used by nodes 1 + 3).
# Default: https://api.github.com
GITHUB_API_URL=https://api.github.com

# ── Runtime flags ─────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Set to 1, true, or yes to skip clone and LLM calls (preview mode only).
DRY_RUN=

# Collision policy when .harness/<name>/ already exists.
# One of: prompt (interactive, default) | skip | continue | overwrite
#   skip      -- do not process the repo (not counted as an error)
#   continue  -- reuse the existing clone as-is (no re-clone)
#   overwrite -- delete the directory and clone fresh
#   prompt    -- ask interactively; falls back to skip if stdin is not a TTY
# CLI flags (--skip/--continue/--overwrite/--on-exist=...) override this.
ON_EXIST=
